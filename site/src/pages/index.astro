---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import { withBase } from "../lib/url";

const things = await getCollection("things");
---

<Base title="Home">
  <h1>A reference of mechanical <em>things</em></h1>
  <p>
    Each entry declares its variables and governing relations, derives them step by step
    (machine-verified), and lets you turn the knobs — including the material — to see the physics
    respond. Built for engineering undergraduates.
  </p>
  <ul class="card-grid">
    {
      things.map((t) => (
        <li class="card">
          <h3>
            <a href={withBase(`things/${t.id}/`)}>{t.data.title}</a>
          </h3>
          <p>{t.data.summary}</p>
          <p>
            {t.data.facets.map((f) => (
              <span class="facet">{f}</span>
            ))}
          </p>
        </li>
      ))
    }
  </ul>
  <p>
    Browse the <a href={withBase("materials/")}>materials database &amp; Ashby chart</a> — every value
    carries its citation and basis. Or watch two THINGs work as one machine in the{" "}
    <a href={withBase("chain-demo/")}>gearbox → shaft chaining demo</a>, where every connection is
    type-checked by dimension <em>and</em> quantity kind.
  </p>
</Base>
