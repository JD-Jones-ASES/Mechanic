---
/**
 * Materials database + Ashby-style chart (invariant 3): log-log stiffness vs
 * density, rendered as pure build-time SVG — ties per-THING material dropdowns
 * back to material-class space. Every plotted point cites its sources below.
 */
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import { withBase } from "../../lib/url";

const rows = (await getCollection("materials")).map((m) => m.data);

const pick = (m: (typeof rows)[number], key: string) => {
  for (const basis of ["typical", "design_minimum", "spec_minimum"]) {
    const p = m.properties.find((p) => p.key === key && p.basis === basis);
    if (p) return p;
  }
  return undefined;
};

const points = rows
  .map((m) => {
    const E = pick(m, "youngs_modulus");
    const rho = pick(m, "density");
    return E && rho ? { m, E: E.value_si, rho: rho.value_si } : null;
  })
  .filter((p) => p != null);

// log-log frame: rho 100..30000 kg/m^3, E 0.1..1000 GPa
const W = 640;
const H = 460;
const PAD = { l: 64, r: 16, t: 16, b: 48 };
const x = (rho: number) =>
  PAD.l + ((Math.log10(rho) - 2) / (Math.log10(30000) - 2)) * (W - PAD.l - PAD.r);
const y = (E_GPa: number) =>
  H - PAD.b - ((Math.log10(E_GPa) - -1) / (3 - -1)) * (H - PAD.t - PAD.b);

const CLASS_COLOR: Record<string, string> = {
  steel: "#475569", stainless: "#0e7490", aluminum: "#2563eb", titanium: "#7c3aed",
  "cast-iron": "#1f2937", "copper-alloy": "#b45309", polymer: "#dc2626",
  wood: "#65a30d", concrete: "#a8a29e",
};
const xTicks = [100, 300, 1000, 3000, 10000, 30000];
const yTicks = [0.1, 1, 10, 100, 1000];
const fmtE = (pa: number) => (pa / 1e9 >= 10 ? (pa / 1e9).toFixed(0) : (pa / 1e9).toPrecision(2));
const classes = [...new Set(points.map((p) => p.m.class))];

// short chart labels (full name + numbers live in the hover title and table);
// the dense metal cluster (~200 GPa, ~7800 kg/m³) is unreadable with full names
const SHORT_LABEL: Record<string, string> = {
  "al-2024-t3": "2024-T3", "al-6061-t6": "6061-T6", "al-7075-t6": "7075-T6",
  "brass-c26000": "Brass 70/30", "concrete-normal": "Concrete",
  "iron-gray-class30": "Gray iron", "nylon-66": "Nylon 6/6", "ss-304": "304 SS",
  "steel-1045": "1045", "steel-4340": "4340", "steel-a36": "A36",
  "ti-6al-4v": "Ti-6Al-4V", "wood-douglas-fir": "Douglas-fir",
};

// greedy label placement: right of the point by default; on collision try the
// left side, then push down a row — build-time, deterministic, 13 points
interface Lbl { px: number; py: number; text: string; anchor: "start" | "end"; ly: number; point: (typeof points)[number]; }
const labels: Lbl[] = [];
for (const p of [...points].sort((a, b) => y(a.E / 1e9) - y(b.E / 1e9))) {
  const px = x(p.rho);
  const py = y(p.E / 1e9);
  let anchor: "start" | "end" = "start";
  let ly = py - 8;
  for (let guard = 0; guard < 8; guard++) {
    const hit = labels.some(
      (o) =>
        Math.abs(o.ly - ly) < 12 &&
        (o.anchor === anchor ? Math.abs(o.px - px) < 110 : Math.abs(o.px - px) < 12),
    );
    if (!hit) break;
    if (anchor === "start") {
      anchor = "end"; // try the left side of the point
    } else {
      anchor = "start"; // back to the right, one row lower
      ly += 12;
    }
  }
  labels.push({ px, py, text: SHORT_LABEL[p.m.id] ?? p.m.name, anchor, ly, point: p });
}
---

<Base title="Materials">
  <h1>Materials</h1>
  <p>
    Stiffness is independent of strength — that's why a "stronger" alloy can deflect <em>more</em>.
    This chart plots Young's modulus against density (both log scales, Ashby-style); the table below
    carries every value's source, basis, and original published units.
  </p>

  <svg viewBox={`0 0 ${W} ${H}`} role="img" aria-label="Ashby chart: Young's modulus vs density, log-log" style="max-width:100%">
    <title>Young's modulus vs density (log–log)</title>
    <desc>Scatter of the materials database; classes share colors. Stiff-and-light is up and left.</desc>
    {xTicks.map((t) => (
      <>
        <line x1={x(t)} y1={PAD.t} x2={x(t)} y2={H - PAD.b} stroke="var(--line)" />
        <text x={x(t)} y={H - PAD.b + 18} text-anchor="middle" font-size="11" fill="currentColor">{t.toLocaleString()}</text>
      </>
    ))}
    {yTicks.map((t) => (
      <>
        <line x1={PAD.l} y1={y(t)} x2={W - PAD.r} y2={y(t)} stroke="var(--line)" />
        <text x={PAD.l - 8} y={y(t) + 4} text-anchor="end" font-size="11" fill="currentColor">{t}</text>
      </>
    ))}
    <text x={(W + PAD.l) / 2} y={H - 8} text-anchor="middle" font-size="12" fill="currentColor">density ρ (kg/m³)</text>
    <text x={16} y={(H - PAD.b + PAD.t) / 2} text-anchor="middle" font-size="12" fill="currentColor" transform={`rotate(-90 16 ${(H - PAD.b + PAD.t) / 2})`}>Young's modulus E (GPa)</text>
    {labels.map((l) => (
      <g>
        <circle cx={l.px} cy={l.py} r="6" fill={CLASS_COLOR[l.point.m.class] ?? "#64748b"} stroke="var(--paper)">
          <title>{l.point.m.name} — E = {fmtE(l.point.E)} GPa, ρ = {Math.round(l.point.rho)} kg/m³ ({l.point.m.condition})</title>
        </circle>
        <text
          x={l.anchor === "start" ? l.px + 9 : l.px - 9}
          y={l.ly}
          text-anchor={l.anchor}
          font-size="10"
          fill="currentColor"
        >
          {l.text}
        </text>
      </g>
    ))}
  </svg>
  <p>
    {classes.map((c) => (
      <span class="facet" style={`border-color:${CLASS_COLOR[c]}`}>{c}</span>
    ))}
  </p>

  <h2>The database</h2>
  <div class="table-scroll">
  <table class="material-props">
    <thead>
      <tr>
        <th scope="col">Material</th><th scope="col">Condition</th><th scope="col">Property</th>
        <th scope="col">Published value</th><th scope="col">SI</th><th scope="col">Basis</th>
        <th scope="col">Source</th>
      </tr>
    </thead>
    <tbody>
      {rows.flatMap((m) =>
        m.properties.map((p, i) => (
          <tr>
            {i === 0 ? <th scope="rowgroup" rowspan={m.properties.length}>{m.name}</th> : null}
            {i === 0 ? <td rowspan={m.properties.length}>{m.condition}</td> : null}
            <td>{p.key.replaceAll("_", " ")}</td>
            <td>{p.value_published} {p.unit_published}</td>
            <td>{p.key === "density" ? `${Math.round(p.value_si)} kg/m³` : p.key === "poisson_ratio" ? p.value_si : `${fmtE(p.value_si)} GPa`}</td>
            <td><span class={`basis basis-${p.basis}`}>{p.basis.replace("_", " ")}</span></td>
            <td class="material-source" title={p.citation}>{p.source_id}</td>
          </tr>
        )),
      )}
    </tbody>
  </table>
  </div>
  <p class="citation">
    Strength values shown in GPa where applicable read as fractions (e.g. 0.25 GPa = 250 MPa).
    Full citations on the <a href={withBase("about/#attributions")}>attributions page</a>.
  </p>
</Base>
