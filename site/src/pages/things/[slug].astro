---
/**
 * The THING template page — every THING renders through this one component
 * (the factory's output side). Static math is KaTeX-rendered at build time;
 * only the widget island ships JS.
 */
import { getCollection, getEntry, render } from "astro:content";
import katex from "katex";
import ThingWidget from "../../components/ThingWidget";
import Base from "../../layouts/Base.astro";
import { accentVarFor } from "../../lib/catalog";
import { thingAudit } from "../../lib/stats";
import { withBase } from "../../lib/url";
import { buildWayfinding } from "../../lib/wayfinding";

export async function getStaticPaths() {
  const things = await getCollection("things");
  return things.map((t) => ({ params: { slug: t.id } }));
}

const { slug } = Astro.params;
const thing = await getEntry("things", slug);
const compiled = await getEntry("compiled", slug);
if (!thing || !compiled) {
  throw new Error(`THING '${slug}' missing authored or compiled entry — run 'pnpm run gen'`);
}

const overviewEntry = await getEntry("prose", `${slug}/overview`);
const failureEntry = await getEntry("prose", `${slug}/failure`);
const Overview = overviewEntry ? (await render(overviewEntry)).Content : null;
const Failure = failureEntry ? (await render(failureEntry)).Content : null;

const binding = compiled.data.material_binding;
const needsMaterials = binding != null;
const allMaterials = needsMaterials ? (await getCollection("materials")).map((m) => m.data) : [];
// per-slot filtering (S17): each slot offers only materials whose cited sources
// publish every property THAT slot binds — a missing value must read as "no
// data", never a silently wrong number. This mirrors the single-binding filter,
// once per slot. materials is slot -> qualifying list (one `default` slot for a
// legacy single-binding THING).
// The SAME qualification predicate is enforced at BUILD time by the R7
// landing-material gate (pipeline `validate_default_materials` /
// `ingest.material_property_coverage`); this filter (here + chain-demo.astro) and
// that gate must stay in step — a build gate looser than this filter could land a
// THING on a material its own dropdown hides.
const hasKeys = (m: (typeof allMaterials)[number], keys: string[]) =>
  keys.every((k) => m.properties.some((p) => p.key === k));
const materials = Object.fromEntries(
  Object.entries(binding ?? {}).map(([slot, binds]) => [
    slot,
    allMaterials.filter((m) => hasKeys(m, Object.values(binds))),
  ]),
);
// page-level note: DB materials this THING cannot fully use (missing at least
// one bound property across any slot — the union of all bound keys).
const allKeys = [...new Set(Object.values(binding ?? {}).flatMap((b) => Object.values(b)))];
const materialsExcluded = allMaterials.filter((m) => !hasKeys(m, allKeys)).length;

const tex = (s: string) => katex.renderToString(s, { displayMode: true, throwOnError: true });
const a = compiled.data;

// build-time wayfinding (ADR-0010 §4): related THINGs, "chains with", prev/next.
// buildWayfinding computes the whole catalog's maps ONCE and memoises them, so the
// O(N²·ports) chain scan runs a single time across all THING page builds, not per page.
const allThings = (await getCollection("things")).map((t) => ({
  id: t.id,
  title: t.data.title,
  summary: t.data.summary,
  category: t.data.category,
  topic: t.data.topic,
  facets: t.data.facets,
}));
const allCompiled = (await getCollection("compiled")).map((c) => c.data);
const wf = buildWayfinding(allThings, allCompiled);
const related = wf.related.get(slug) ?? [];
const chains = wf.chains.get(slug) ?? { targets: [], totalTargets: 0 };
const neighbors = wf.neighbors.get(slug) ?? {};
const chainsOverflow = chains.totalTargets - chains.targets.length;

// per-THING verification badge counts — the SAME shared helper /verification/
// uses, so the two surfaces can never disagree (the wayfinding e2e pins it).
const audit = thingAudit(a);
const catAccent = accentVarFor(thing.data.category);

// static material chips (invariant 3, the Ashby loop): the distinct materials this
// THING can bind, each linking to its /materials/ row. Display-only build-time HTML
// — the live selection stays in the widget island, no new client JS. Deduped across
// slots (a material qualifying for two slots is listed once).
const materialChips = needsMaterials
  ? [...new Map(Object.values(materials).flat().map((m) => [m.id, m])).values()].sort((x, y) =>
      x.name.localeCompare(y.name),
    )
  : [];
---

<Base title={thing.data.title} description={thing.data.summary}>
  <article>
    <h1>{thing.data.title}</h1>
    <p>{thing.data.facets.map((f) => <span class="facet">{f}</span>)}</p>

    <a class="verify-badge" href={withBase(`verification/#${slug}`)} data-pagefind-ignore>
      <span class="verify-badge-key">Verified build</span>
      <span class="verify-badge-counts">
        <span data-badge="relations">{audit.relations}</span> relations ·{" "}
        <span data-badge="identities">{audit.identities}</span> identities proven ·{" "}
        <span data-badge="modeling">{audit.modeling}</span> modeling step{audit.modeling === 1 ? "" : "s"} ·{" "}
        <span data-badge="samples">{audit.samples}</span> parity samples
      </span>
    </a>

    {Overview ? <Overview /> : null}

    <h2>Try it</h2>
    <div data-pagefind-ignore>
      <ThingWidget client:load artifact={a} materials={materials} sim={a.sim} />
      {
        materialsExcluded > 0 && (
          <p class="citation">
            {materialsExcluded} material{materialsExcluded === 1 ? "" : "s"} in the database{" "}
            {materialsExcluded === 1 ? "is" : "are"} not listed here: no published value in our
            cited sources for every property this THING needs.
          </p>
        )
      }
      {
        materialChips.length > 0 && (
          <p class="material-chips">
            <span class="material-chips-label">Materials modeled here:</span>{" "}
            {materialChips.map((m) => (
              <a class="material-chip" href={withBase(`materials/#${m.id}`)}>
                {m.name}
              </a>
            ))}
          </p>
        )
      }
    </div>

    <h2>Governing relations</h2>
    {
      a.relations.map((rel) => (
        <div class="relation-block">
          <Fragment set:html={tex(rel.latex)} />
          <p class="assumptions">
            <strong>Assumes:</strong> {rel.assumptions.join("; ") || "—"}
            {rel.validity.length > 0 && (
              <>
                {" "}
                · <strong>Valid while:</strong> {rel.validity.map((v) => v.message).join(" ")}
              </>
            )}
          </p>
          <p class="citation">
            Source: {a.sources.find((s) => s.id === rel.citation)?.citation ?? rel.citation}
          </p>
        </div>
      ))
    }

    <h2>Derivation</h2>
    <p class="citation">
      Steps marked <span class="step-definition">modeling step</span> are where physics enters by
      citation — every other line is machine-proven to follow from them, and the cited models are
      independently re-derived in the test pipeline where possible. See{" "}
      <a href="../../verification/">what is and isn't machine-verified</a>.
    </p>
    <div class="derivation">
      {
        a.derivation.map((step, i) => (
          <div class="derivation-step">
            <Fragment set:html={tex(step.latex)} />
            <p>
              <strong>{i + 1}.</strong> {step.prose}
              {step.rule ? <span class="rule"> — {step.rule}</span> : null}
              {step.check === "definition" ? <span class="step-definition"> modeling step</span> : null}
            </p>
          </div>
        ))
      }
    </div>

    <h2>How it fails</h2>
    {Failure ? <Failure /> : <p>Failure notes pending.</p>}

    {
      related.length > 0 && (
        // data-pagefind-ignore: these are cross-references to OTHER THINGs' titles;
        // indexing them would make this page a low-rank hit for a neighbour's name,
        // the same listing-noise D1/PFN removed. The THING stays indexed for its own
        // content (the page's data-pagefind-body); only the wayfinding is skipped.
        <section class="wayfinding" aria-labelledby="related-heading" data-pagefind-ignore>
          <h2 id="related-heading">Related THINGs</h2>
          <ul class="thing-grid" role="list">
            {related.map((r) => (
              <li class="thing-card" style={`--cat-accent: var(${accentVarFor(r.category)})`}>
                <a class="thing-card-link" href={withBase(`things/${r.id}/`)}>
                  {r.title}
                </a>
                <p class="thing-card-summary">{r.summary}</p>
                <ul class="facet-row" role="list">
                  {r.facets.map((f) => (
                    <li class="facet">{f}</li>
                  ))}
                </ul>
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <section class="wayfinding" aria-labelledby="chains-heading" data-pagefind-ignore>
      <h2 id="chains-heading">Chains with</h2>
      {chains.targets.length === 0 ? (
        <p class="citation">
          None of this THING's outputs match another THING's input by dimension <em>and</em>{" "}
          quantity kind, so the type checker accepts no outbound wire (invariant 2).
        </p>
      ) : (
        <>
          <p class="citation">
            Outputs whose SI dimension <em>and</em> quantity kind match another THING's input — the
            only wires the planner's <code>connectionLegal</code> accepts (invariant 2, computed at
            build time, not hand-listed). Wire these on the <a href={withBase("chain-demo/")}>chaining demo</a>.
          </p>
          <ul class="chains-list" role="list">
            {chains.targets.map((tg) => (
              <li class="chains-target">
                <a class="chains-target-link" href={withBase(`things/${tg.toThing}/`)}>
                  {tg.toTitle}
                </a>
                <ul class="port-wires" role="list">
                  {tg.wires.map((w) => (
                    <li class="port-wire" data-wire={`${w.fromPort}|${tg.toThing}|${w.toPort}`}>
                      <code>{w.fromPort}</code>
                      <span class="port-arrow" aria-hidden="true">→</span>
                      <code>{w.toPort}</code>
                    </li>
                  ))}
                </ul>
              </li>
            ))}
          </ul>
          {chainsOverflow > 0 && (
            <p class="citation">
              + {chainsOverflow} more THING{chainsOverflow === 1 ? "" : "s"} its outputs can legally
              feed (showing the first {chains.targets.length} in course order).
            </p>
          )}
        </>
      )}
    </section>

    <h2>Sources</h2>
    <ul>
      {
        a.sources.map((s) => (
          <li class="citation">
            {s.url ? <a href={s.url}>{s.citation}</a> : s.citation}
          </li>
        ))
      }
    </ul>

    <nav class="thing-nav" aria-label="Course sequence" style={`--cat-accent: var(${catAccent})`} data-pagefind-ignore>
      {neighbors.prev ? (
        <a class="thing-nav-link thing-nav-prev" rel="prev" href={withBase(`things/${neighbors.prev.id}/`)}>
          <span class="thing-nav-dir">← Previous</span>
          <span class="thing-nav-title">{neighbors.prev.title}</span>
        </a>
      ) : (
        <span class="thing-nav-spacer" />
      )}
      {neighbors.next ? (
        <a class="thing-nav-link thing-nav-next" rel="next" href={withBase(`things/${neighbors.next.id}/`)}>
          <span class="thing-nav-dir">Next →</span>
          <span class="thing-nav-title">{neighbors.next.title}</span>
        </a>
      ) : (
        <span class="thing-nav-spacer" />
      )}
    </nav>
  </article>
</Base>
