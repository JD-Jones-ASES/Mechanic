---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import { withBase } from "../../lib/url";

const things = await getCollection("things");
---

<Base title="Things">
  <h1>Things</h1>
  <ul class="card-grid">
    {
      things.map((t) => (
        <li class="card">
          <h3>
            <a href={withBase(`things/${t.id}/`)}>{t.data.title}</a>
          </h3>
          <p>{t.data.summary}</p>
          <p>
            {t.data.facets.map((f) => (
              <span class="facet">{f}</span>
            ))}
          </p>
        </li>
      ))
    }
  </ul>
</Base>
